# ----------------------------------------------------------------------------
# Copy to `.env` and adjust. NEVER commit a real .env (see .gitignore).
# ----------------------------------------------------------------------------

# Which repository adapter the app wires at boot. "postgres" | "memory".
# This single switch is the proof of Dependency Inversion (see README §Decision log).
STORE_DRIVER=postgres

# Postgres connection string. Required when STORE_DRIVER=postgres; the app
# refuses to boot without it (fail-fast config validation).
DATABASE_URL=postgres://app:app@localhost:5432/transfers

# HTTP
PORT=3000

# Ingestion safety limit — reject batches larger than this (cheap DoS guard).
MAX_BATCH_SIZE=1000

# Logging
LOG_LEVEL=info
NODE_ENV=development
